{
  "expo": {
    "name": "Prospia Admin",
    "slug": "prospia-admin",
    "owner": "sguelfand",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0f172a"
    },
    "android": {
      "package": "net.prospia.admin",
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "apiUrl": "https://prospia.app/api",
      "eas": {
        "projectId": "17ef09d1-5518-4962-a5e9-243563659460"
      }
    },
    "plugins": [
      "expo-asset",
      [
        "expo-notifications",
        {
          "color": "#6366f1"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir que Prospia Admin use Face ID para desbloquear la app."
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/17ef09d1-5518-4962-a5e9-243563659460"
    },
    "ios": {}
  }
}
