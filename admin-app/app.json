{
  "expo": {
    "name": "Prospia",
    "slug": "prospia-admin",
    "owner": "sguelfand",
    "version": "1.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C1730"
    },
    "android": {
      "package": "net.prospia.admin",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C1730"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "apiUrl": "https://prospia.app/api",
      "eas": {
        "projectId": "17ef09d1-5518-4962-a5e9-243563659460"
      }
    },
    "plugins": [
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#F5B23D"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir que Prospia use Face ID para desbloquear la app."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Prospia necesita acceso a tus fotos para adjuntar una captura de la conversación a un registro de calidad."
        }
      ],
      "expo-font",
      "@react-native-voice/voice"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/17ef09d1-5518-4962-a5e9-243563659460"
    },
    "ios": {
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Prospia usa el micrófono para hablarle por voz a las sesiones de Claude.",
        "NSSpeechRecognitionUsageDescription": "Prospia transcribe tu voz para mandarle mensajes a las sesiones de Claude."
      }
    }
  }
}