{
  "expo": {
    "name": "Prospia",
    "slug": "prospia-admin",
    "owner": "sguelfand",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C1730"
    },
    "android": {
      "package": "net.prospia.admin",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C1730"
      }
    },
    "extra": {
      "apiUrl": "https://prospia.app/api",
      "eas": {
        "projectId": "17ef09d1-5518-4962-a5e9-243563659460"
      }
    },
    "plugins": [
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#F5B23D"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir que Prospia use Face ID para desbloquear la app."
        }
      ],
      "expo-font"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/17ef09d1-5518-4962-a5e9-243563659460"
    },
    "ios": {}
  }
}
